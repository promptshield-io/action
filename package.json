{
  "name": "@promptshield-io/action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action for PromptShield",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf .promptshield/ && ncc build src/index.ts -o dist --minify --no-cache",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "biome check ./src --write"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@promptshield/cli": "latest",
    "@types/node": "^25.7.0",
    "@vercel/ncc": "^0.38.4",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "github-action",
    "promptshield",
    "promptlint",
    "security",
    "prompt-injection",
    "ai-security",
    "llm-security"
  ]
}
