{
  "name": "@promptshield-io/action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action for PromptShield",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf .promptshield/ && ncc build src/index.ts -o dist --minify --no-cache"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@promptshield/cli": "latest",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.7.0",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "github-action",
    "promptshield",
    "promptlint",
    "security",
    "prompt-injection",
    "ai-security",
    "llm-security"
  ]
}
